# ─── TELEGRAM ────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
BOT_TOKEN=8840435597:AAHnVfOLF6Zbt2O8I-sJSLWL--lmC-SsVMs

# Your personal Telegram user ID (get from @userinfobot)
ADMIN_USER_ID=7495097942

# ─── AI APIs (ALL FREE TIERS) ────────────────────────────────────────

# Groq — Primary AI (LLaMA 3 70B)
# Free: 14,400 req/day | Get key: console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenRouter — Fallback AI (Mistral, many free models)
# Free: Various free models | Get key: openrouter.ai
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# Google Gemini — Fallback AI (Gemini Pro)
# Free: 60 req/min | Get key: aistudio.google.com
GEMINI_API_KEY=your_google_gemini_api_key_here

# DeepSeek — Last Resort AI
# Free: Generous limits | Get key: platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ─── CRYPTO DATA APIs ────────────────────────────────────────────────

# CoinMarketCap — Basic plan (free)
# Free: 333 calls/day | Get key: coinmarketcap.com/api/
CMC_API_KEY=your_coinmarketcap_api_key_here

# NOTE: DexScreener = NO KEY NEEDED (fully open)
# NOTE: CoinGecko = NO KEY NEEDED for basic endpoints

# ─── DATABASE ────────────────────────────────────────────────────────
DB_PATH=data/nexusbot.db

# ─── BOT SETTINGS ────────────────────────────────────────────────────
LOG_LEVEL=INFO
TIMEZONE=UTC
ALERT_INTERVAL_MINUTES=30
MAX_RESULTS=10
BOT_NAME=NexusBot

# ─── SCHEDULER INTERVALS (minutes) ──────────────────────────────────
# Adjust these to control how often alerts fire
ALPHA_SCAN_INTERVAL=5
TRENDING_SCAN_INTERVAL=10
JOB_SCAN_INTERVAL=60
WHALE_SCAN_INTERVAL=15
